{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PomoTimer",
  "version": "0.2.0",
  "identifier": "com.pomotimer.desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PomoTimer",
        "width": 160,
        "height": 220,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "center": true,
        "shadow": true,
        "minWidth": 150,
        "minHeight": 200
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self' blob:"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "PomoTimer",
      "id": "main-tray"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["sounds/*"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
